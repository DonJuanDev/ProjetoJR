DATABASE_URL="postgresql://postgres:password@localhost:5432/gateway_db"

JWT_SECRET="sua-chave-jwt-super-secreta-mude-em-producao"

# Throttle global (Nest Throttler): requisições por IP na janela abaixo (webhooks e /health ignoram)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=200

# MAC do QR da comanda (`?sig=` na URL impressa) — recarga no caixa valida quando preenchido no banco
QR_SECRET="sua-chave-qr-super-secreta-mude-em-producao"

PORT=3001FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

NODE_ENV="development"

# Mercado Pago - Obtenha em: https://www.mercadopago.com.br/developers
# Use credenciais de TESTE para desenvolvimento
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MP_PUBLIC_KEY="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
MP_WEBHOOK_SECRET="sua-chave-webhook-mp"
